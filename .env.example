# SERVER CONFIGURATION
PORT=4000
NODE_ENV=development

# SUPABASE CREDENTIALS
# The URL of your Supabase project (found in Project Settings > API)
SUPABASE_URL=https://your-project-id.supabase.co

# The anonymous key allows operations bounded by Row Level Security (RLS)
SUPABASE_ANON_KEY=your-anon-public-key

# The service role key bypasses Row Level Security (RLS)
# WARNING: Keep this key highly secure! Only use for background system operations.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
